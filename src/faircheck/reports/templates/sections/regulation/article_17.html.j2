<section class="page-break">
    <h1>EU AI Act — Article 17: Quality Management System</h1>
    <p class="regulation-ref">Reference: Regulation (EU) 2024/1689, Article 17</p>

    {% set art17 = regulation_report.article_mappings | selectattr('article', 'equalto', 'Article 17') | first %}

    <div class="requirement-box">
        <h3>Requirement</h3>
        <p>{{ art17.requirement }}</p>
    </div>

    <div class="status-badge status-{{ art17.status }}">
        Status: {{ art17.status | replace('_', ' ') | title }}
    </div>

    <h3>Evidence</h3>
    <p>{{ art17.evidence }}</p>

    <h3>Audit Trail</h3>
    <table>
        <tr><td><strong>Session ID</strong></td><td>{{ report.session_id or 'N/A' }}</td></tr>
        <tr><td><strong>Scan Date</strong></td><td>{{ report.scan_date or 'N/A' }}</td></tr>
        <tr><td><strong>Model</strong></td><td>{{ report.model_name or 'N/A' }}</td></tr>
    </table>

    <h3>Recommendations</h3>
    <ul>
        <li>Re-assess model fairness on a regular schedule (e.g., quarterly)</li>
        <li>Monitor for distributional drift in input data</li>
        <li>Maintain versioned records of all bias assessments</li>
        <li>Document any model retraining or hyperparameter changes</li>
        <li>Ensure human oversight review is completed before each deployment cycle</li>
    </ul>
</section>
